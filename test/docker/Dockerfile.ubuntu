FROM node:22

# Set working directory inside container
WORKDIR /app

# Enable corepack for pnpm support
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

# Copy package configuration files
COPY package.json pnpm-lock.yaml tsconfig.json ./

# Install dependencies using pnpm
RUN pnpm install --frozen-lockfile

# Copy source code and test files
COPY src/ ./src/
COPY bin/ ./bin/
COPY test/ ./test/

# Build project
RUN pnpm build

# Ensure no system ffmpeg or yt-dlp is installed and clear any cache
RUN rm -f /usr/bin/ffmpeg /usr/local/bin/ffmpeg /usr/bin/yt-dlp /usr/local/bin/yt-dlp && \
    rm -rf ~/.cache/mux-yt/bin

# Default command runs the verification test for auto-downloading dependencies
CMD ["pnpm", "exec", "tsx", "test/verify-auto-download.ts"]
